# ============================================================
# SKUA — Environment Variable Template
# Copy to .env and fill in all values before running the bot.
# NEVER commit .env to source control.
# NEVER log or print private key values.
# ============================================================

# ── Network ──────────────────────────────────────────────────
SKUA_CHAIN_ID=999
# MUST be a private dedicated RPC — NEVER the public endpoint
SKUA_RPC_WS_URL=wss://YOUR_PRIVATE_WS_ENDPOINT
SKUA_RPC_HTTP_URL=https://YOUR_PRIVATE_HTTP_ENDPOINT
SKUA_RPC_FALLBACK_URL=wss://YOUR_FALLBACK_WS_ENDPOINT

# HyperCore WebSocket (public — read-only order book feed)
HYPERCORE_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERCORE_API_URL=https://api.hyperliquid.xyz

# ── Contracts (set after deployment) ─────────────────────────
# NEVER commit real addresses until contracts are audited
SKUA_BALANCER_VAULT=0x
SKUA_HYPERLEND_POOL=0x
SKUA_CONTRACT_EVM_ARB=0x
SKUA_CONTRACT_LIQ=0x
SKUA_CONTRACT_TRI=0x
SKUA_CONTRACT_DEPEG=0x
# Cold wallet — NEVER a bot hot wallet
SKUA_PROFIT_WALLET=0x
# DEX router for collateral→debt swaps (S2) — set at deployment
SKUA_DEX_ROUTER=0x

# ── HyperCore market / token indices ─────────────────────────
# Verify against HyperLiquid documentation before deployment
SKUA_HYPE_MARKET_INDEX=
SKUA_USDC_TOKEN_INDEX=

# ── Bot hot wallet private keys ───────────────────────────────
# NEVER on disk in plaintext in production. Use a secrets manager.
# Keys 1-5 are required. Keys 6-10 are optional (more = better throughput).
SKUA_BOT_KEY_1=0x
SKUA_BOT_KEY_2=0x
SKUA_BOT_KEY_3=0x
SKUA_BOT_KEY_4=0x
SKUA_BOT_KEY_5=0x
# SKUA_BOT_KEY_6=0x
# SKUA_BOT_KEY_7=0x
# SKUA_BOT_KEY_8=0x

# ── Strategy minimum profit floors (USD) ─────────────────────
SKUA_S1_MIN_PROFIT_USD=1.00
SKUA_S2_MIN_PROFIT_USD=50.00
SKUA_S3_MIN_PROFIT_USD=0.50
SKUA_S4_MIN_PROFIT_USD=1.00

# ── Capital ceiling ───────────────────────────────────────────
# Start conservatively. Scale after confirmed profitable history.
SKUA_HARD_CAP_USD=100000

# ── ROI multiplier on gas cost ────────────────────────────────
SKUA_GAS_ROI_MULTIPLIER=1.5

# ── Signal thresholds ─────────────────────────────────────────
SKUA_S1_SIGNAL_BPS=60.0
SKUA_S4_DEPEG_BPS=15.0

# ── gasPrice multipliers ──────────────────────────────────────
# At HyperEVM near-zero gas cost, aggressive multipliers are effectively free.
SKUA_GASPRICE_ARB=50
SKUA_GASPRICE_LIQ=200
SKUA_GASPRICE_DEPEG=300

# ── Circuit breakers ─────────────────────────────────────────
SKUA_MAX_CONSECUTIVE_REVERTS=3
# Kill switch: max HYPE spent in window before auto-halt
SKUA_GAS_KILL_HYPE=0.5
SKUA_GAS_KILL_WINDOW_SECS=3600

# ── API server ────────────────────────────────────────────────
SKUA_API_PORT=3001
# Generate with: openssl rand -hex 32
SKUA_API_KEY=REPLACE_WITH_RANDOM_64_HEX_CHARS

# ── Telegram alerts ───────────────────────────────────────────
SKUA_TELEGRAM_BOT_TOKEN=
SKUA_TELEGRAM_CHAT_ID=

# ── Foundry (for contract deployment) ────────────────────────
SKUA_TESTNET_RPC=https://YOUR_TESTNET_RPC
HYPEREVM_EXPLORER_KEY=
HYPEREVM_EXPLORER_URL=

# ── HyperLend monitored assets (AUDIT FIX #1) ─────────────────────────────
# Comma-separated list of token addresses to monitor for liquidations.
# Get these from the HyperLend protocol's getReservesList() at deployment.
SKUA_HYPERLEND_ASSETS=0x...,0x...,0x...

# ── S4 Stable tokens (AUDIT FIX #2) ──────────────────────────────────────
# Format: SYMBOL:TOKEN_ADDR:ORACLE_IDX:DECIMALS:POOL_A_ADDR:POOL_B_ADDR
SKUA_S4_STABLE_1=USDC:0x...:0:6:0x...:0x...
SKUA_S4_STABLE_2=USDT:0x...:1:6:0x...:0x...
SKUA_S4_STABLE_3=feUSD:0x...:2:18:0x...:0x...
# SKUA_S4_STABLE_4=USDH:0x...:3:18:0x...:0x...  # Add when Hyperliquid publishes address

# ── DEX router (AUDIT FIX #3) ─────────────────────────────────────────────
# Router contract for collateral→debt swaps in S2 liquidations.
# Set after confirming the DEX deployed on HyperEVM testnet.
SKUA_DEX_ROUTER=0x
